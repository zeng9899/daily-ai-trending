{
  "models": {
    "providers": {
      "zhipu": {
        "baseUrl": "https://open.bigmodel.cn/api/paas/v4",
        "apiKey": "YOUR_ZHIPU_API_KEY",
        "api": "openai-completions",
        "models": [
          {
            "id": "glm-4.5-air",
            "name": "GLM-4.5-Air",
            "contextWindow": 200000,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "zhipu/glm-4.5-air"
      },
      "workspace": "./workspace"
    }
  },
  "skills": {
    "install": {
      "nodeManager": "npm"
    },
    "entries": {
      "mcporter": {
        "enabled": true
      }
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback"
  }
}
